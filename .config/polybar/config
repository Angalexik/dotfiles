[colors]
nord0 = #2e3440
nord1 = #3b4252
nord2 = #434c5e
nord3 = #4c566a
nord4 = #d8dee9
nord5 = #e5e9f0
nord6 = #eceff4
nord7 = #8fbcbb
nord8 = #88c0d0
nord9 = #81a1c1
nord10 = #5e81ac
nord11 = #bf616a
nord12 = #d08770
nord13 = #ebcb8b
nord14 = #a3be8c
nord15 = #b48ead

[bar/mybar]
modules-right = z pulseaudio s filesystem a xkeyboard s date a power
modules-left = xwindow d
modules-center = i3
background = ${colors.nord1}
foreground = ${colors.nord4}
font-0 = "SF Pro Text:size=13;3"
font-1 = "Sauce Code Pro Nerd Font Mono:size=17;4"
height = 20
padding =
scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev

[module/date]
type = internal/date
time = %H:%M
label =  %time%
format-background = ${colors.nord8}

[module/s]
type = custom/text
content = 
content-foreground = ${colors.nord8}
content-background = ${colors.nord3}
content-font = 2

[module/a]
type = custom/text
content = 
content-foreground = ${colors.nord3}
content-background = ${colors.nord8}
content-font = 2

[module/d]
type = custom/text
content = 
content-foreground = ${colors.nord3}
content-font = 2

[module/z]
type = custom/text
content = 
content-foreground = ${colors.nord3}

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock
blacklist-1 = scroll lock
blacklist-2 = caps lock
format =  <label-layout>
format-background = ${colors.nord3}

[module/xwindow]
type = internal/xwindow
label-empty = Desktop
label-background = ${colors.nord3}
label-maxlen = 50
label-empty-background = ${colors.nord3}
label-padding = 1
label-empty-padding = 1

[module/i3]
type = internal/i3
enable-scroll = false
label-focused-padding = 2
label-unfocused-padding = 2
label-focused = 
label-unfocused = 

[module/filesystem]
type = internal/fs
mount-0 = /
format-mounted = <label-mounted>
label-mounted =  %percentage_used%% of %total%
label-mounted-background = ${colors.nord8}

[module/pulseaudio]
type = internal/pulseaudio
use-ui-max = false
interval = 5
format-volume = <ramp-volume> <label-volume>
format-muted = ﱝ mt%
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 
format-volume-background = ${colors.nord3}
format-muted-background = ${colors.nord3}

[module/power]
type = custom/text
content = 
content-background = ${colors.nord3}
click-left = shutdown now &
